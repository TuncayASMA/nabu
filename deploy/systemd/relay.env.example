# Copy to /etc/nabu/relay.env and chmod 600
# sudo mkdir -p /etc/nabu && sudo cp relay.env.example /etc/nabu/relay.env
# sudo chmod 600 /etc/nabu/relay.env && sudo chown nabu:nabu /etc/nabu/relay.env

# Pre-shared key (must match client).
# Generate: openssl rand -hex 32
NABU_PSK=change-me

# UDP listen address for the relay.
NABU_RELAY_LISTEN=:7000

# Per-source rate limit in packets/sec (0 = disabled).
NABU_RATE_LIMIT=100
