# Copy to /etc/nabu/client.env and chmod 600
# sudo mkdir -p /etc/nabu && sudo cp client.env.example /etc/nabu/client.env
# sudo chmod 600 /etc/nabu/client.env && sudo chown nabu:nabu /etc/nabu/client.env

# Relay address (host:port).
NABU_RELAY_ADDR=your.relay.host:7000

# Pre-shared key (must match relay).
NABU_PSK=change-me

# Local SOCKS5 listen address.
NABU_SOCKS_LISTEN=127.0.0.1:1080
