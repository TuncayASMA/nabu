# syntax=docker/dockerfile:1
# ----- build stage -----
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG TARGETOS=linux
ARG TARGETARCH
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH:-arm64} \
    go build -trimpath -ldflags="-s -w" \
    -o /out/nabu-relay ./cmd/nabu-relay

# ----- runtime stage -----
FROM gcr.io/distroless/static:nonroot
COPY --from=builder /out/nabu-relay /nabu-relay
EXPOSE 7000/udp
ENTRYPOINT ["/nabu-relay"]
