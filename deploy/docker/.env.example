# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# Pre-shared key for AES-256-GCM encryption.
# Generate a strong random key: openssl rand -hex 32
NABU_PSK=change-me-use-openssl-rand-hex-32

# UDP port the relay listens on (server-side).
NABU_RELAY_PORT=7000

# TCP port the local SOCKS5 proxy listens on (client-side).
NABU_SOCKS_PORT=1080

# Relay address as seen by the client.
# On the same Docker network the service name "nabu-relay" resolves automatically.
# For a remote relay replace with: your.server.ip:7000
NABU_RELAY_ADDR=nabu-relay:7000
