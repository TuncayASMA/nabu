# syntax=docker/dockerfile:1
# ----- build stage -----
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG TARGETOS=linux
ARG TARGETARCH
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH:-arm64} \
    go build -trimpath -ldflags="-s -w" \
    -o /out/nabu-client ./cmd/nabu-client

# ----- runtime stage -----
FROM gcr.io/distroless/static:nonroot
COPY --from=builder /out/nabu-client /nabu-client
EXPOSE 1080/tcp
ENTRYPOINT ["/nabu-client"]
